# Style C# du front Windows — source de vérité pour `dotnet format` et
# les analyzers Roslyn (DOTNET_QU002).
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.cs]
indent_style = space
indent_size = 4

[*.{xaml,csproj,manifest,appxmanifest}]
indent_style = space
indent_size = 2
