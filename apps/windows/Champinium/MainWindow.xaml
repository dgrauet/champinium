<?xml version="1.0" encoding="utf-8"?>
<!-- Fenêtre principale : en-tête + barre de connexion + onglets
     Abonnements/Explorer + lecteur. Miroir WinUI 3 du ContentView SwiftUI
     (macOS). Présentation uniquement — aucun filtrage ici : le catalogue
     Abonnements vient de `catalog_subscribed()`, le catalogue Explorer de
     `catalog()`, tous deux calculés par le core.

     Pivot (pas SelectorBar) : disponible sans condition de version dans
     Microsoft.UI.Xaml.Controls depuis les premières releases de WinUI 3,
     alors que SelectorBar n'a été ajouté qu'à partir de WindowsAppSDK 1.4 —
     choix conservateur vu la version de PackageReference du csproj (2.3.1,
     non alignée sur le schéma de versions WinAppSDK habituel — à vérifier en
     CI, voir rapport de tâche).

     Binding classique PARTOUT dans ce fichier (zéro x:Bind) — un DataTemplate
     x:Bind en ressource nommée partagée par plusieurs ListView générait un
     connecteur ancré sur la Window (CS1503, plusieurs itérations en CI) ; par
     prudence, plus aucun x:Bind n'est utilisé, y compris au niveau Window, une
     fois que la structure du fichier inclut un Pivot (ItemsControl). Le
     DataContext de la Grid racine est posé sur `Model` en code-behind
     (MainWindow.xaml.cs, après InitializeComponent) — tous les
     `{Binding …}` de ce fichier résolvent dessus, sauf ceux des DataTemplate
     dont le DataContext est l'item (ChannelGroup/CatalogCid). -->
<Window
    x:Class="Champinium.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Champinium"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Champinium">

    <!-- Window n'a pas de propriété XAML `Resources` en WinUI 3 (WMC0011) —
         les ressources partagées vivent dans Grid.Resources de la racine ;
         toutes leurs utilisations sont à l'intérieur de cette grille. -->
    <Grid x:Name="Root" Padding="16" RowSpacing="12">
        <Grid.Resources>
            <local:EmptyStringToVisibilityConverter x:Key="EmptyStringToVisibility" />
            <local:NonEmptyStringToVisibilityConverter x:Key="NonEmptyStringToVisibility" />
            <local:BooleanToVisibilityConverter x:Key="BooleanToVisibility" />
            <local:InverseBooleanConverter x:Key="InverseBoolean" />

            <!-- Gabarit partagé : un groupe (créateur/channel) = en-tête (nom, seq,
                 bouton abonnement) + ses contenus. Le bouton d'abonnement est au
                 niveau du GROUPE, jamais sur une ligne de contenu individuelle.

                 `Binding` classique (PAS `x:Bind`) : un `DataTemplate` déclaré en
                 ressource nommée (`x:Key`), partagé par deux `ListView`, génère un
                 connecteur `x:Bind` ancré sur la `Window` plutôt que sur l'item —
                 `Window` n'étant pas un `FrameworkElement` en WinUI 3, ça ne
                 compile pas (CS1503, deux tentatives de variantes `x:Bind` déjà
                 essayées sans succès en CI). Le `Binding` classique n'a pas ce
                 problème : chaque conteneur d'item pose son `DataContext` sur
                 l'instance (`ChannelGroup`/`CatalogCid`) — pas besoin de `x:DataType`
                 ni de `Tag` pour la retrouver, `OnToggleSubscriptionClick` la relit
                 via `(sender as FrameworkElement)?.DataContext`. -->
            <DataTemplate x:Key="ChannelGroupTemplate">
                <StackPanel Spacing="4" Padding="0,8">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="0">
                            <TextBlock Text="{Binding DisplayName}"
                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding SeqText}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                <!-- État du seed proactif (lot c) — vide pour un feed sans publication. -->
                                <TextBlock Text="{Binding SeedStatusText}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1" Content="{Binding SubscribeLabel}"
                                Click="OnToggleSubscriptionClick" />
                        <!-- Blocage local de channel (tâche d/6) — Explorer uniquement,
                             voir ChannelGroup.CanBlock. Confirmation en code-behind. -->
                        <Button Grid.Column="2" Content="Bloquer"
                                Visibility="{Binding CanBlock, Converter={StaticResource BooleanToVisibility}}"
                                Click="OnBlockClick" />
                    </Grid>
                    <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="8" Padding="12,2,0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Display}"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="NoWrap" />
                                        <TextBlock Text="{Binding TagsText}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                   TextWrapping="NoWrap" />
                                    </StackPanel>
                                    <!-- Pin par publication (lot c) — masqué côté Explorer,
                                         voir CatalogCid.CanPin. -->
                                    <Button Grid.Column="1" Content="{Binding PinLabel}"
                                            Visibility="{Binding CanPin, Converter={StaticResource BooleanToVisibility}}"
                                            Click="OnTogglePinClick" />
                                    <Button Grid.Column="2" Content="Lire"
                                            Tag="{Binding Cid}" Click="OnPlayClick" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </DataTemplate>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- En-tête : titre, statut, PeerId, réglages de seed -->
        <Grid Grid.Row="0" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="Champinium" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock Text="{Binding Status, Mode=OneWay}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <!-- PeerId du nœud (vide tant que le nœud n'est pas ouvert). -->
                <TextBlock Text="{Binding PeerId, Mode=OneWay}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           TextWrapping="NoWrap" />
            </StackPanel>
            <!-- Réglages de seed (lot c) : quota en Go + usage courant, en Flyout
                 pour rester cohérent avec la vue unique existante (pas de fenêtre
                 de réglages séparée). -->
            <Button Grid.Column="1" VerticalAlignment="Top" Content="Réglages de seed">
                <Button.Flyout>
                    <Flyout>
                        <StackPanel Spacing="10" Width="240">
                            <TextBlock Text="Quota de seeding" Style="{StaticResource BaseTextBlockStyle}" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         PlaceholderText="Go"
                                         Text="{Binding QuotaField, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Column="1" Content="Enregistrer" Click="OnSaveSeedQuotaClick" />
                            </Grid>
                            <TextBlock Text="{Binding StorageStatsText, Mode=OneWay}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>
            <!-- Réglages : liste des channels bloqués localement (tâche d/6) —
                 même patron de Flyout que "Réglages de seed". -->
            <Button Grid.Column="2" VerticalAlignment="Top" Content="Channels bloqués">
                <Button.Flyout>
                    <Flyout>
                        <StackPanel Spacing="8" Width="280">
                            <TextBlock Text="Channels bloqués" Style="{StaticResource BaseTextBlockStyle}" />
                            <ListView ItemsSource="{Binding BlockedChannels, Mode=OneWay}"
                                      SelectionMode="None"
                                      MaxHeight="200">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding DisplayText}"
                                                       FontFamily="Consolas"
                                                       Style="{StaticResource CaptionTextBlockStyle}" />
                                            <Button Grid.Column="1" Content="Débloquer" Click="OnUnblockClick" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>
        </Grid>

        <!-- Barre de connexion : multiaddr du pair + Connecter / Rafraîchir -->
        <Grid Grid.Row="1" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     PlaceholderText="/ip4/…/tcp/…/p2p/&lt;peerid&gt;"
                     Text="{Binding PeerField, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Button Grid.Column="1" Content="Connecter" Click="OnConnectClick" />
            <Button Grid.Column="2" Content="Rafraîchir" Click="OnRefreshClick" />
        </Grid>

        <!-- Recherche locale : titres et tags du catalogue reconstruit -->
        <TextBox Grid.Row="2"
                 PlaceholderText="Rechercher (titre ou tag)…"
                 Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <Border Grid.Row="3" Height="1"
                Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <!-- Résultats de recherche : remplacent les onglets tant que la requête
             n'est pas vide (les deux catalogues restent inchangés en dessous). -->
        <ListView Grid.Row="4"
                  Visibility="{Binding SearchQuery, Mode=OneWay, Converter={StaticResource NonEmptyStringToVisibility}}"
                  ItemsSource="{Binding SearchResults, Mode=OneWay}"
                  SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnSpacing="8" Padding="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding Display}"
                                       TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap" />
                            <TextBlock Text="{Binding TagsText}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                       TextWrapping="NoWrap" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="Lire"
                                Tag="{Binding Cid}" Click="OnPlayClick" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Onglets Abonnements (défaut) / Explorer, visibles hors recherche. -->
        <Pivot Grid.Row="4" x:Name="CatalogPivot"
               Visibility="{Binding SearchQuery, Mode=OneWay, Converter={StaticResource EmptyStringToVisibility}}"
               SelectedIndex="0"
               SelectionChanged="OnPivotSelectionChanged">
            <PivotItem Header="Abonnements">
                <ListView ItemsSource="{Binding SubscribedGroups, Mode=OneWay}"
                          ItemTemplate="{StaticResource ChannelGroupTemplate}"
                          SelectionMode="None" />
            </PivotItem>
            <PivotItem Header="Explorer">
                <StackPanel Spacing="12">
                    <!-- Abonnement par lien + copie du lien de mon propre channel —
                         visibles uniquement dans l'onglet Explorer (même choix que
                         le jumeau macOS). -->
                    <StackPanel Spacing="6">
                        <!-- Aperçu (pas d'abonnement direct au collage, voir tâche 3) :
                             résout le lien/PeerId puis ouvre une feuille d'aperçu ;
                             l'abonnement se décide depuis cette feuille. -->
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     PlaceholderText="Coller un lien de channel…"
                                     Text="{Binding ChannelLinkField, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <ProgressRing Grid.Column="1"
                                          Width="20" Height="20"
                                          IsActive="{Binding IsPreviewLoading, Mode=OneWay}"
                                          Visibility="{Binding IsPreviewLoading, Mode=OneWay, Converter={StaticResource BooleanToVisibility}}" />
                            <Button Grid.Column="2" Content="Aperçu"
                                    IsEnabled="{Binding IsPreviewLoading, Mode=OneWay, Converter={StaticResource InverseBoolean}}"
                                    Click="OnPreviewByLinkClick" />
                        </Grid>
                        <Button Content="Copier le lien de mon channel" Click="OnCopyMyLinkClick" />
                        <TextBlock Text="{Binding SubscriptionStatus, Mode=OneWay}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <ListView ItemsSource="{Binding ExploreGroups, Mode=OneWay}"
                              ItemTemplate="{StaticResource ChannelGroupTemplate}"
                              SelectionMode="None" />
                </StackPanel>
            </PivotItem>
        </Pivot>

        <!-- Lecteur média (Media Foundation via MediaPlayerElement) -->
        <MediaPlayerElement Grid.Row="5"
                            x:Name="Player"
                            AreTransportControlsEnabled="True"
                            MinHeight="220" />
    </Grid>
</Window>
