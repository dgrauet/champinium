<?xml version="1.0" encoding="utf-8"?>
<!-- Fenêtre principale : en-tête + barre de connexion + catalogue + lecteur.
     Miroir WinUI 3 du ContentView SwiftUI (macOS). Présentation uniquement. -->
<Window
    x:Class="Champinium.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Champinium"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Champinium">

    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- En-tête : titre, statut, PeerId -->
        <StackPanel Grid.Row="0" Spacing="2">
            <TextBlock Text="Champinium" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="{x:Bind Model.Status, Mode=OneWay}"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <!-- PeerId du nœud (vide tant que le nœud n'est pas ouvert). -->
            <TextBlock Text="{x:Bind Model.PeerId, Mode=OneWay}"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       TextWrapping="NoWrap" />
        </StackPanel>

        <!-- Barre de connexion : multiaddr du pair + Connecter / Rafraîchir -->
        <Grid Grid.Row="1" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     PlaceholderText="/ip4/…/tcp/…/p2p/&lt;peerid&gt;"
                     Text="{x:Bind Model.PeerField, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Button Grid.Column="1" Content="Connecter" Click="OnConnectClick" />
            <Button Grid.Column="2" Content="Rafraîchir" Click="OnRefreshClick" />
        </Grid>

        <!-- Recherche locale : titres et tags du catalogue reconstruit -->
        <TextBox Grid.Row="2"
                 PlaceholderText="Rechercher (titre ou tag)…"
                 Text="{x:Bind Model.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <Border Grid.Row="3" Height="1"
                Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <!-- Catalogue (ou résultats de recherche) : un item par contenu -->
        <ListView Grid.Row="4"
                  ItemsSource="{x:Bind Model.Entries, Mode=OneWay}"
                  SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:CatalogCid">
                    <Grid ColumnSpacing="8" Padding="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{x:Bind Header}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <!-- Titre du contenu, ou CID si sans titre -->
                            <TextBlock Text="{x:Bind Display}"
                                       TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap" />
                            <TextBlock Text="{x:Bind TagsText}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                       TextWrapping="NoWrap" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="Lire"
                                Tag="{x:Bind Cid}" Click="OnPlayClick" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Lecteur média (Media Foundation via MediaPlayerElement) -->
        <MediaPlayerElement Grid.Row="5"
                            x:Name="Player"
                            AreTransportControlsEnabled="True"
                            MinHeight="220" />
    </Grid>
</Window>
